{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(git clone:*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.git-credentials)",
      "Read(~/.config/gh/**)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.profile)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/session-start-kb-check.sh",
            "statusMessage": "Surfacing LL-G / BP knowledge-base reminder..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash .claude/scripts/check-commit-herestring.sh",
            "statusMessage": "Checking commit message syntax..."
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash .claude/scripts/pre-commit-changelog-reminder.sh",
            "statusMessage": "Checking changelog update..."
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash .claude/scripts/check-changelog-staged.sh",
            "statusMessage": "Verifying changelog is staged..."
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/pre-plan-kb-check.sh",
            "statusMessage": "Checking LL-G and BP knowledge bases..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash .claude/scripts/post-commit-kb-contribute.sh",
            "statusMessage": "Checking for knowledge base contributions..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ]
  },
  "plansDirectory": "tasks"
}
