{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "//": "Personal overrides. Copy to settings.local.json (git-ignored) and edit. settings.local.json deep-merges over settings.json and is never committed.",

  "//disableAllHooks": "Kill switch for ALL hooks (commit checks, KB nudges, bell). Set true if the team hooks get in your way locally.",
  "disableAllHooks": false,

  "//alwaysThinkingEnabled": "Force extended thinking every turn. Useful on gnarly codebases.",
  "alwaysThinkingEnabled": false,

  "//language": "Preferred response language, e.g. 'en', 'ja', 'es'.",
  "language": "en"
}
