{
  "name": "pandamux",
  "version": "0.15.11",
  "description": "PandaMUX Everywhere: Windows terminal multiplexer for AI agents",
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.18.0",
    "pnpm": ">=11.10.0"
  },
  "main": "dist/main/index.js",
  "bin": {
    "pandamux": "dist/cli/pandamux.js"
  },
  "scripts": {
    "dev": "concurrently \"vite --port 5199\" \"wait-on http://localhost:5199 && electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.11",
    "electron-updater": "^6.8.9",
    "marked": "^18.0.5",
    "node-pty": "^1.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^10.6.0",
    "rcedit": "^5.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
