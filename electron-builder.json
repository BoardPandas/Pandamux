{
  "appId": "com.pandamux.app",
  "productName": "PandaMUX Everywhere",
  "executableName": "pandamux",
  "directories": {
    "output": "release"
  },
  "publish": {
    "provider": "github",
    "owner": "BoardPandas",
    "repo": "Pandamux"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "node_modules/**/*",
    "!**/*.ts",
    "!**/*.tsx",
    "!src/**/*",
    "!docs/**/*",
    "!tests/**/*"
  ],
  "asarUnpack": [
    "**/*.node"
  ],
  "win": {
    "icon": "resources/icons/icon.ico",
    "target": [
      { "target": "dir", "arch": ["x64"] }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "PandaMUX Everywhere"
  },
  "portable": {
    "artifactName": "pandamux-${version}-portable.exe"
  },
  "extraResources": [
    { "from": "resources/icon.png", "to": "icon.png" },
    { "from": "resources/themes", "to": "themes" },
    { "from": "resources/sounds", "to": "sounds" },
    { "from": "resources/claude-instructions.md", "to": "claude-instructions/claude-instructions.md" },
    { "from": "src/shell-integration", "to": "shell-integration" },
    { "from": "dist/cli/pandamux.js", "to": "cli/pandamux.js" },
    { "from": "resources/pandamux-orchestrator", "to": "pandamux-orchestrator" }
  ]
}
